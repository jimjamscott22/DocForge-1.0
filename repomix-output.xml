.markdown-preview h3:first-child { margin-top: 0; }
.markdown-preview p { margin-bottom: 0.75rem; line-height: 1.7; }
.markdown-preview a { color: #fb923c; text-decoration: underline; text-underline-offset: 2px; }
.markdown-preview a:hover { color: #fdba74; }
.markdown-preview strong { color: #e7e5e4; font-weight: 600; }
.markdown-preview ul { list-style: disc; padding-left: 1.5rem; margin-bottom: 0.75rem; }
.markdown-preview ol { list-style: decimal; padding-left: 1.5rem; margin-bottom: 0.75rem; }
.markdown-preview li { margin-bottom: 0.25rem; line-height: 1.6; }
.markdown-preview li > ul,
